# === Template d'environnement — copier en .env et remplir les valeurs ===

# --- Application Symfony ---
APP_ENV=dev
APP_SECRET=
APP_DEBUG=1

# --- Base URL publique (utilisée par Symfony pour générer les liens) ---
DEFAULT_URI=http://localhost

# --- CORS (origine autorisée pour les requêtes API depuis le frontend) ---
CORS_ALLOW_ORIGIN=http://localhost:5173

# --- Frontend React (injecté au moment du build Vite) ---
# Dev  : http://localhost  (Vite contacte le backend Caddy:80)
# Prod : https://mondomaine.com
VITE_API_URL=http://localhost

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL="postgresql://**********:changeme@database:5432/*********?serverVersion=16&charset=utf8"

# --- MongoDB ---
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DB=
MONGODB_URL="mongodb://******:*******@mongodb:27017/?authSource=admin"

# --- JWT (Authentification) ---
JWT_SECRET_KEY=
JWT_PUBLIC_KEY=
JWT_PASSPHRASE=a_strong_passphrase

# --- Mailer ---
# Dev  : smtp://mailer:1025  (Mailpit)
# Prod : smtp://user:password@smtp.provider.com:587
MAILER_DSN=smtp://mailer:1025

# --- Symfony Messenger ---
MESSENGER_TRANSPORT_DSN=sync://