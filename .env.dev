# Fichier d'environnement de développement (modèle)
# Ce fichier DOIT être commité sur Git.
# Il sert de modèle pour la configuration de développement.
# Copiez ce fichier vers .env.local pour votre configuration personnelle.

# --- Application Symfony ---
APP_ENV=dev
# !! Ce secret est un exemple, Symfony le surchargera avec le vrai secret de votre coffre-fort (vault) !!
APP_SECRET=c2a7f8e1b4d0f3e2a1c9b8d7e6f5a4b3

# --- Base de données PostgreSQL ---
# Utilisées par Docker Compose et par Symfony
POSTGRES_USER=plantuser
POSTGRES_PASSWORD=plantpassword
POSTGRES_DB=plantodb

# --- Base de données MongoDB ---
MONGODB_DB=plantoshop_db

# --- URL construites par Docker Compose (pas besoin de les redéfinir ici) ---
# DATABASE_URL="postgresql://plantuser:plantpassword@database:5432/plantodb?serverVersion=16&charset=utf8"
# MONGODB_URL="mongodb://mongodb:27017/plantoshop_db"
